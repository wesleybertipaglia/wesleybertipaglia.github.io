---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/basic/Container.astro";
import Link from "../components/basic/Link.astro";
---

<BaseLayout title="About Me" description="Lorem ipsum dolor sit amet">
  <Container>
    <h1 class="text-4xl">Hello there! 👋</h1>
    <hr class="mb-6" />
    <p>
      I'm Wesley Bertipaglia, a 24-year-old web developer based in Brazil. I
      find joy in the ever-evolving world of technology, constantly exploring
      and playing with different tech stacks to keep things exciting.
    </p>

    <p>
      By day, I'm immersed in the world of full-stack web development,
      particularly in the realm of JavaScript and .NET. I love the challenge of
      crafting digital experiences and bringing ideas to life through code.
    </p>

    <p>
      When I'm not coding, you'll often find me with headphones on, immersed in
      the soothing vibes of lofi music.
    </p>

    <p>
      Feel free to explore my personal website to get a glimpse of my work and
      interests. If you share a love for technology, music, or just want to
      connect, don't hesitate to reach out. Let's build something amazing
      together! 🚀
    </p>

    <div class="inline-flex gap-3 mt-2 align-baseline">
      <h2 class="m-0 text-xl">Let's work together:</h2>
      <p class="flex gap-2 text-neutral-500 text-xl">
        <Link
          href="https://drive.google.com/file/d/1PEI3HoMLNT7zi4pVWM__hSbVH-w_6X7S/view"
          class:list={"hover:text-cyan-400"}
          target="_blank"
        >
          Resume
        </Link>
        <Link
          href="https://linkedin.com/in/wesley-bertipaglia"
          class:list={"hover:text-cyan-400"}
          target="_blank"
        >
          Linkedin
        </Link>
      </p>
    </div>
  </Container>
</BaseLayout>
