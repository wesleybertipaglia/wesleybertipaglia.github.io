---
import { BLOG } from '@consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/Container.astro';
import PostPreview from '@components/PostPreview.astro';
import Pagination from '@components/Pagination.astro';
import Search from '@components/Search.astro';
import { PaginationUtils } from '@lib/pagination-utils';
import { TagUtils } from '@lib/tag-utils';
import { QueryUtils } from '@lib/query-utils';

const allBlogPosts = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const q = Astro.url.searchParams.get('q');
const tag = Astro.url.searchParams.get('tag');
let filteredPosts = allBlogPosts;
if (q) {
  filteredPosts = QueryUtils.filterPostsByQuery(filteredPosts, q);
}
if (tag) {
  filteredPosts = TagUtils.filterPostsByTag(filteredPosts, tag);
}

const pagination = PaginationUtils.getPagination({ url: Astro.url });
const totalPages = Math.ceil(filteredPosts.length / pagination.size);
const blogPosts = filteredPosts.slice(
  pagination.offset,
  pagination.offset + pagination.size
);

const params = new URLSearchParams(Astro.url.search);
params.delete('page');
params.delete('size');
const otherParams = params.toString();

const title =
  q && tag
    ? `${BLOG.title} - Search: ${q} in tag: ${tag}`
    : q
      ? `${BLOG.title} - Search: ${q}`
      : tag
        ? `${BLOG.title} tagged with "${tag}"`
        : BLOG.title;
---

<PageLayout title={title} description={BLOG.description}>
  <section class="flex flex-col flex-1">
    <Container class="flex flex-col flex-1 w-full">
      <div class="flex-1">
        <h1 class="text-xl font-bold mb-6">Blog</h1>

        <Search />

        <ul class="flex flex-col gap-4">
          {
            blogPosts.length > 0 ? (
              blogPosts.map((post: any) => (
                <li>
                  <PostPreview post={post} />
                </li>
              ))
            ) : (
              <li>{q ? `No posts found for "${q}"` : 'No posts found'}</li>
            )
          }
        </ul>
      </div>

      {
        totalPages > 0 && (
          <Pagination
            currentPage={pagination.page}
            totalPages={totalPages}
            basePath="/blog"
            size={pagination.size}
            otherParams={otherParams}
          />
        )
      }
    </Container>
  </section>
</PageLayout>

<script>
  import { pageUtils } from '@lib/page-utils';
  pageUtils.initBlogPage();
</script>
