---
import { BLOG } from "@consts";
import { getCollection, type CollectionEntry } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import PostPreview from "@components/PostPreview.astro";
import Pagination from "@components/Pagination.astro";
import { paginationUtils } from "@lib/pagination";

const allBlogPosts = (await getCollection("blog")).sort(
	(a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
		b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pagination = paginationUtils.getPagination({ url: Astro.url });
const totalPages = Math.ceil(allBlogPosts.length / pagination.size);
const blogPosts = allBlogPosts.slice(
	pagination.offset,
	pagination.offset + pagination.size,
);
---

<PageLayout title={BLOG.title} description={BLOG.description}>
	<section class="flex flex-col flex-1">
		<Container class="flex flex-col flex-1">
			<div class="flex-1">
				<h1 class="text-xl font-bold mb-6">Blog</h1>

				<ul class="flex flex-col gap-4">
					{
						blogPosts.length > 0 ? (
							blogPosts.map((post: any) => (
								<li>
									<PostPreview post={post} />
								</li>
							))
						) : (
							<li>No posts found</li>
						)
					}
				</ul>
			</div>

			{
				totalPages > 0 && (
					<Pagination
						currentPage={pagination.page}
						totalPages={totalPages}
						basePath="/blog"
						size={pagination.size}
					/>
				)
			}
		</Container>
	</section>
</PageLayout>

<script>
	import { pageUtils } from "@lib/page-utils";
	pageUtils.initBlogPage();
</script>
