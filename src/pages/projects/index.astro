---
import { PROJECTS } from '@consts';
import { getCollection, type CollectionEntry } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/Container.astro';
import PostPreview from '@components/PostPreview.astro';
import Pagination from '@components/Pagination.astro';
import Search from '@components/Search.astro';

const projectsPosts = (await getCollection('projects')).sort(
  (a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = PROJECTS.title;
---

<PageLayout title={title} description={PROJECTS.description}>
  <section class="flex flex-col flex-1">
    <Container class="flex flex-col flex-1 w-full">
      <div class="flex-1">
        <h1 class="text-xl font-bold mb-6">Projects</h1>

        <Search />

        <ul class="flex flex-col gap-4">
          {
            projectsPosts.length > 0 ? (
              projectsPosts.map((post: any) => (
                <li>
                  <PostPreview post={post} />
                </li>
              ))
            ) : (
              <li>No posts found</li>
            )
          }
        </ul>
      </div>

      <Pagination
        currentPage={1}
        totalPages={1}
        basePath="/projects"
        size={10}
      />
    </Container>
  </section>
</PageLayout>

<script>
  import { pageUtils } from '@lib/page-utils';
  pageUtils.initProjectsPage();
</script>
