---
import Scaffold from "../layouts/Scaffold.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_SEPARATOR } from "../consts";
import Hero from "../components/structure/Hero.astro";
import About from "../components/structure/About.astro";
import Skills from "../components/structure/Skills.astro";
import Stack from "../components/structure/Stack.astro";
import Experience from "../components/structure/Experience.astro";
import Education from "../components/structure/Education.astro";
import Contact from "../components/structure/Contact.astro";
import ListPosts from "../components/structure/ListPosts.astro";
import { PostView } from "../utils/Post";
---

<Scaffold
  title={SITE_DESCRIPTION}
  description={SITE_TITLE + SITE_SEPARATOR + SITE_DESCRIPTION}
>
  <Hero />
  <About />
  <Skills />
  <Stack />
  <Experience />
  <Education />
  <ListPosts
    title="Recent Projects"
    view={PostView.normal}
    slice={5}
    showAll={true}
    type="projects"
  />
  <ListPosts
    title="Recent Posts"
    view={PostView.normal}
    slice={5}
    showAll={true}
    type="blog"
  />
  <Contact />
</Scaffold>
