---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_SEPARATOR } from "../consts";
import Hero from "../components/base/Hero.astro";
import About from "../components/base/About.astro";
import Skills from "../components/base/Skills.astro";
import Stack from "../components/base/Stack.astro";
import Experience from "../components/base/Experience.astro";
import Education from "../components/base/Education.astro";
import Contact from "../components/base/Contact.astro";
import ListPosts from "../components/basic/ListPosts.astro";
import { PostView } from "../utils/Post";
---

<BaseLayout
  title={SITE_DESCRIPTION}
  description={SITE_TITLE + SITE_SEPARATOR + SITE_DESCRIPTION}
>
  <Hero />
  <About />
  <Skills />
  <Stack />
  <Experience />
  <Education />
  <ListPosts
    title="Recent Projects"
    view={PostView.normal}
    slice={5}
    showAll={true}
    type="projects"
  />
  <ListPosts
    title="Recent Posts"
    view={PostView.normal}
    slice={5}
    showAll={true}
    type="blog"
  />
  <Contact />
</BaseLayout>
