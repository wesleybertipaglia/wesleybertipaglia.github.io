---
import BaseLayout from "../layouts/BaseLayout.astro";
import ListLayout from "../layouts/ListLayout.astro";
import { PostView } from "../utils/Post";
import Hero from "../components/base/Hero.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_SEPARATOR } from "../consts";
---

<BaseLayout
  title={SITE_DESCRIPTION}
  description={SITE_TITLE + SITE_SEPARATOR + SITE_DESCRIPTION}
>
  <Hero />
  <ListLayout
    title="Recent Posts"
    view={PostView.compact}
    slice={5}
    showAll={true}
    type="blog"
  />
  <ListLayout
    title="Recent Projects"
    view={PostView.compact}
    slice={5}
    showAll={true}
    type="projects"
  />
</BaseLayout>
