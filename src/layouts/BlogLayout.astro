---
import { type CollectionEntry, getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/Container.astro';
import { DateUtils } from '@lib/date-utils';
import { TextUtils } from '@lib/text-utils';
import { TableOfContentsUtils } from '@lib/table-of-contents-utils';
import Share from '@components/Share.astro';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const series = post.data.series
  ? (await getCollection('series')).find((s) => s.data.id === post.data.series)
  : null;
const toc = TableOfContentsUtils.generateTOC(post.body);
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  section={post.data.tags ? post.data.tags[0] : undefined}
>
  <Container>
    <article>
      <div class="pb-4">
        <h1 class="text-4xl font-bold">{post.data.title}</h1>
        <p class="text-sm">
          {DateUtils.formatDate({ date: post.data.pubDate })} • {
            TextUtils.readingTime({ text: post.body })
          }
        </p>
        <Share
          title={post.data.title}
          description={post.data.description}
          url={`${Astro.site}${post.collection}/${post.slug}`}
        />
      </div>

      <figure>
        <img
          src={post.data.cover || '/images/placeholder.webp'}
          alt={post.data.title}
          class="w-full h-64 object-cover rounded-lg"
        />
      </figure>

      {
        toc.length > 0 && (
          <details class="my-4">
            <summary class="text-lg font-semibold cursor-pointer">
              Table of Contents
            </summary>
            <ul class="space-y-1 mt-4 overflow-hidden transition-max-height duration-300 ease-in-out">
              {toc.map((item) => (
                <li style={`padding-left: ${(item.level - 1) * 20}px;`}>
                  <a
                    href={`#${item.id}`}
                    class="text-sm text-blue-400 hover:underline"
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        )
      }

      <style>
        details summary::marker {
          font-size: 0.8em;
        }
        details > ul {
          transition: max-height 0.3s ease-in-out;
        }
        details:not([open]) > ul {
          max-height: 0;
        }
        details[open] > ul {
          max-height: 1000px;
        }
      </style>

      {
        series && (
          <p class="my-4">
            Part of the series:
            <a href={`/series/${series.slug}`} class="underline">
              {series.data.title}
            </a>
          </p>
        )
      }

      <div id="content" class="mb-8">
        <slot />
      </div>

      {
        post.data.tags && (
          <div>
            <p class="mb-0 mt-8 italic">Tags:</p>

            <div class="flex gap-2 mt-4">
              {post.data.tags.map((tag: string) => (
                <a href={`/${post.collection}/?tag=${tag}`}>
                  <span class="text-sm bg-background-3/50 text-color-3/75 px-2 py-1 rounded">
                    {tag}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </article>
  </Container>
</PageLayout>
