---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { formatDate, readingTime } from "@lib/utils";
import Share from "@components/Share.astro";

type Props = {
	post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const series = post.data.series
	? (await getCollection("series")).find(
			(s) => s.data.id === post.data.series,
		)
	: null;
---

<PageLayout
	title={post.data.title}
	description={post.data.description}
	image={post.data.cover}
>
	<Container>
		<article>
			<div>
				<h1 class="text-3xl font-bold">{post.data.title}</h1>
				<p class="text-sm">
					{formatDate({ date: post.data.pubDate })} • {readingTime({ text: post.body })}
				</p>
			</div>

			<figure>
				<img
					src={post.data.cover || "/images/placeholder.webp"}
					alt={post.data.title}
					class="w-full h-64 object-cover rounded-lg"
				/>
			</figure>

			{
				series && (
					<p class="py-4">
						Part of the series:
						<a href={`/series/${series.slug}`} class="underline">
							{series.data.title}
						</a>
					</p>
				)
			}

			<div id="content" class="mb-16">
				<slot />
			</div>

			<Share
				title={post.data.title}
				description={post.data.description}
				url={`${Astro.site}${post.collection}/${post.slug}`}
			/>

			{
				post.data.tags && (
					<div>
						<p class="mb-0 mt-8 italic">Tags:</p>

						<div class="flex gap-2 mt-4">
							{post.data.tags.map((tag: string) => (
								<a href={`/${post.collection}/?tag=${tag}`}>
									<span class="text-sm bg-light-background-3/50 dark:bg-dark-background-3/50 text-light-text-3/75 dark:text-dark-text-3/75 px-2 py-1 rounded">
										{tag}
									</span>
								</a>
							))}
						</div>
					</div>
				)
			}
		</article>
	</Container>
</PageLayout>
