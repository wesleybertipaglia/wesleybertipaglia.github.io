---
const { placeholder = "Search..." } = Astro.props;
const { pathname } = Astro.url;
const action = pathname.includes("/blog")
    ? "/blog"
    : pathname.includes("/projects")
      ? "/projects"
      : pathname.includes("/series")
        ? "/series"
        : pathname.includes("/work")
          ? "/work"
          : "/";
---

<form method="get" action={action} class="mb-4">
    <div class="relative">
        <input
            type="text"
            name="q"
            placeholder={placeholder}
            class="w-full py-3 px-4 pr-10 rounded border border-light-border-3/10 dark:border-dark-border-3/10 bg-transparent text-light-text-3 dark:text-dark-text-3 hover:bg-light-background-3/10 dark:hover:bg-dark-background-3/10 focus:bg-light-background-3/10 dark:focus:bg-dark-background-3/10 transition-colors duration-300 ease-in-out"
        />
        <button
            type="submit"
            class="absolute top-1/2 right-2 mr-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current text-light-text-3 dark:text-dark-text-3"
        >
            <svg
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
        </button>
    </div>
</form>
