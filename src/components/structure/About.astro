---
import Container from "../basic/Container.astro";
import LinkTree from "../specific/LinkTree.astro";
import { social } from "../../data/links";
---

<Container id="about" class:list={"flex flex-col gap-4 my-12"}>
  <div class="flex flex-col gap-2">
    <h2 class="font-bold text-xl">About me</h2>
    <p>
      Hello, my name is Wesley, since I was very young I have been passionate
      about exploring the potential of technology and its infinite
      possibilities. As a developer, my focus is on creating functional,
      scalable applications that not only solve real-world problems, but also
      drive innovation and transform experiences.
    </p>
  </div>

  <LinkTree type="horizontal" links={social} />
</Container>
