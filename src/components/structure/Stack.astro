---
import Container from "../basic/Container.astro";
import stack from "../../data/stack.js";
import StackCategory from "../specific/StackCategory.astro";
---

<header>
  <Container id="stack" class:list={"py-6  my-12 flex flex-col gap-4"}>
    <div class="flex flex-col gap-2">
      <h2 class="font-bold text-xl">Stack</h2>

      <p class="text-text-2">
        Here are some of the technologies I've been working with recently:
      </p>
    </div>

    <StackCategory category="Front-end" stack={stack.frontend} />

    <StackCategory category="Back-end" stack={stack.backend} />

    <StackCategory category="Tools" stack={stack.tools} />
  </Container>
</header>
