---
import FormattedDate from "../helpers/FormattedDate.astro";
import { PostView } from "../../utils/Post";
import Link from "./Link.astro";

interface Props {
  post: any;
  view: PostView;
  postCollection?: string;
}
const { post, view, postCollection } = Astro.props;
---

{
  view === PostView.normal ? (
    <Link href={`${postCollection}/${post.slug}/`}>
      <img src={post.data.image?.url} alt={post.data.image?.alt} />
      <h4 class="title">{post.data.title}</h4>
      <p class="date">
        <FormattedDate date={post.data.pubDate} />
      </p>
    </Link>
  ) : (
    <div class="flex justify-between gap-6">
      <Link href={`/${postCollection}/${post.slug}/`}>
        <p class="title">{post.data.title}</p>
      </Link>
      <p class="date">
        <FormattedDate date={post.data.pubDate} />
      </p>
    </div>
  )
}
