---
import Container from "../../components/basic/Container.astro";
import { getCollection } from "astro:content";
import PostPreview from "./PostPreview.astro";
import { PostView } from "../../utils/Post";
import Link from "./Link.astro";

interface Props {
  collection?: string;
  tag?: string;
  title?: string;
  showAll: boolean;
  slice?: number;
}
const { collection, tag, title, showAll, slice } = Astro.props;

let posts = (await getCollection("post")).sort(
  (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);

if (tag != undefined)
  posts = posts.filter((post) => post.data.tags?.find((x) => x == tag));
if (slice != undefined) posts = posts.slice(0, slice);
---

<Container classList="py-6">
  <section>
    {title != undefined ? <h4 class="text-xl">{title}</h4> : ""}
    {
      posts.map((post) => (
        <PostPreview
          post={post}
          view={PostView.compact}
          collection={collection}
        />
      ))
    }
    {showAll ? <Link href={"/" + collection}>All posts →</Link> : ""}
  </section>
</Container>
