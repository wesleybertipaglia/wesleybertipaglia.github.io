---
import Link from "../basic/Link.astro";
import Container from "../basic/Container.astro";

interface Props {
  theme?: string;
  user: string;
}
const { user, theme } = Astro.props;

let imgSrc = `https://stackoverflow.com/users/flair/${user}.png`;
imgSrc = theme != undefined ? (imgSrc += `?theme=${theme}`) : imgSrc;
---

<Container>
  <Link href=`https://stackoverflow.com/users/${user}`>
    <img
      src={imgSrc}
      width="208"
      height="58"
      alt=`profile for ${user} at Stack Overflow, Q&A for professional and enthusiast programmers`
      title=`profile for ${user} at Stack Overflow, Q&A for professional and enthusiast programmers`
    />
  </Link>
</Container>
