---
import Iframe from "../basic/Iframe.astro";
import { Size } from "../../utils/Base";

interface Props {
  title?: string;
  src: string;
  theme?: boolean;
  size?: Size;
}

function getSize() {
  if (size == Size.compact || size == undefined) {
    return "152px";
  } else {
    return "352px";
  }
}

const { title, src, theme, size } = Astro.props;
let iframeHeight = getSize();
---

<Iframe
  title={title != undefined ? title : "Spotify Playlist"}
  src={src + (theme ? "" : "&theme=0")}
  class:list={"w-full rounded-md border-0 outline-0"}
  height={iframeHeight}
/>
