---
import { Icon } from 'astro-icon/components';
import { ShareUtils } from '@lib/share-utils';
import Modal from './Modal.astro';

interface Props {
  title: string;
  description?: string;
  url: string;
}

const { title, description, url } = Astro.props;
const socialLinks = ShareUtils.getSocialLinks(title, description, url);
---

<div class="border-b border-border-3/10 pb-2 mb-2">
  <button
    id="share-button"
    title="Share this post"
    class="px-2 py-2 bg-background-3/50 text-color-3 rounded hover:bg-background-3 hover:bg-dark-background-3 transition-colors cursor-pointer"
  >
    <Icon name="icons/share" class="w-4 h-4" />
  </button>

  <Modal
    title="Share this post"
    modalId="share-modal"
    closeButtonId="close-share-modal"
  >
    <div class="mb-4">
      <label class="block text-sm font-medium mb-2">Copy link</label>
      <div class="flex gap-2">
        <input
          id="share-url"
          type="text"
          value={url}
          readonly
          class="flex-1 px-3 py-2 bg-background-3 text-color-1 rounded border border-border-3/10"
        />
        <button
          id="copy-button"
          title="Copy to clipboard"
          class="px-3 py-2 bg-background-3/50 text-color-3 rounded hover:bg-background-3 hover:bg-dark-background-3 transition-colors cursor-pointer"
        >
          <Icon name="icons/copy" class="w-4 h-4 copy-icon" />
          <Icon name="icons/check" class="w-4 h-4 check-icon hidden" />
        </button>
      </div>
    </div>
    <div class="flex flex-col gap-2">
      {
        socialLinks.map((socialLink) => (
          <a
            href={socialLink.url}
            target="_blank"
            rel="noopener noreferrer"
            class="relative group flex items-center gap-4 py-3 px-4 rounded transition-colors duration-300 ease-in-out border
            border-border-3/10
            hover:bg-background-3/10 hover:bg-dark-background-3/10 text-color-3 hover:text-color-2 hover:text-dark-text-2"
          >
            <Icon
              name={`socials/${socialLink.icon}`}
              class="w-5 h-5 shrink-0 text-color-3"
            />
            <span class="flex-1 text-color-3">{socialLink.name}</span>
            <Icon name="icons/arrow-outward" class="w-5 h-5 text-color-3" />
          </a>
        ))
      }
    </div>
  </Modal>
</div>

<script>
  import { ModalUtils } from '../lib/modal-utils.js';
  import { ShareUtils } from '../lib/share-utils.js';
  ModalUtils.initModal('share-modal', 'share-button', 'close-share-modal');
  ShareUtils.initCopy('copy-button', 'share-url');
</script>
