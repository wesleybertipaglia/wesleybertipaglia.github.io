---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  modalId?: string;
  closeButtonId?: string;
}

const { title, modalId = 'modal', closeButtonId = 'close-modal' } = Astro.props;
---

<div
  id={modalId}
  class="modal-overlay fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center"
>
  <div
    class="modal-content bg-background-1 p-6 rounded-lg max-w-md w-full mx-4"
  >
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold m-0">{title}</h3>
      <button
        id={closeButtonId}
        class="text-color-3 hover:text-color-1 hover:text-dark-text-1 cursor-pointer"
      >
        <Icon name="icons/x" class="w-5 h-5" />
      </button>
    </div>
    <slot />
  </div>
</div>
